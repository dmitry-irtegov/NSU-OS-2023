#include <stdio.h>
#include <stdlib.h>

int main() {
    char line[BUFSIZ];

    FILE* in = popen("echo Hello, World!", "r");
    if (in == NULL) {
        perror("Error with popen");
        return -1;
    }

    FILE* out = popen("tr [:lower:] [:upper:]", "w");
    if (out == NULL) {
        perror("Error with popen");
        return -1;
    }

    while (fgets(line, BUFSIZ, in) != NULL) {
        if (fputs(line, out) == -1) {
            perror("Error with fputs");
            return -1;
        }
    }

    if (pclose(in) == -1) {
        perror("Error with pclose");
        return -1;
    }

    if (pclose(out) == -1) {
        perror("Error with pclose");
        return -1;
    }

    return 0;
}
